name: Refresh And Deploy Scholarship Radar

on:
  workflow_dispatch:
  schedule:
    - cron: "17 3,15 * * *"

permissions:
  contents: write
  pages: write
  id-token: write

concurrency:
  group: scholarship-radar-pages
  cancel-in-progress: true

jobs:
  refresh-and-deploy:
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Configure GitHub Pages
        uses: actions/configure-pages@v5

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Refresh scholarship data
        run: npm run refresh

      - name: Commit refreshed data
        run: |
          if git diff --quiet -- data/scholarships.json; then
            echo "No scholarship data changes to commit."
          else
            git config user.name "github-actions[bot]"
            git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
            git add data/scholarships.json
            git commit -m "chore: refresh scholarship radar data"
            git push
          fi

      - name: Build site artifact
        run: npm run build

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v4
        with:
          path: dist

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
